PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/armando_portfolio

JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

FRONTEND_URL=http://localhost:3000

# TEMPORARY — disable before production
ALLOW_REGISTER_ADMIN=false

# Optional seed (node src/scripts/seedAdmin.js)
SEED_ADMIN_NAME=Armando Mora
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated hostnames allowed as canonical URL origins (e.g. yourdomain.com,www.yourdomain.com)
ALLOWED_CANONICAL_HOSTS=
